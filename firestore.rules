
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read and write access to the weather and settings collections
    // This is for demonstration purposes. For a production app, you should
    // implement more secure rules.
    match /weather/{document=**} {
      allow read, write: if true;
    }
    match /settings/{document=**} {
      allow read, write: if true;
    }
  }
}
